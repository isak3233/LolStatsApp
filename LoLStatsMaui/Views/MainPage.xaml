<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="LoLStatsMaui.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    x:Name="ThisPage"
    BackgroundColor="#0A1428">
    <Grid RowDefinitions="Auto, *">

        <HorizontalStackLayout
            Margin="16,16,0,0"
            HorizontalOptions="Start"
            VerticalOptions="Start">
            <Button
                Command="{Binding NavigateToLinkAccountCommand}"
                IsVisible="{Binding IsLoggedIn}"
                Text="Länka ett LoL konto"
                TextColor="White" />
        </HorizontalStackLayout>

        <HorizontalStackLayout
            Margin="0,16,16,0"
            HorizontalOptions="End"
            Spacing="8"
            VerticalOptions="Start">
            <Button
                Command="{Binding NavigateToMyAccountCommand}"
                IsVisible="{Binding IsLoggedIn}"
                Text="Mitt konto"
                TextColor="White" />
            <Button
                Command="{Binding NavigateToLoginCommand}"
                Text="{Binding LoginBtnText}"
                TextColor="White" />
            <Button
                Command="{Binding NavigateToCreateUserCommand}"
                IsVisible="{Binding IsLoggedIn, Converter={toolkit:InvertedBoolConverter}}"
                Text="Registrera användare"
                TextColor="White" />
        </HorizontalStackLayout>

        <Label
            Grid.Row="0"
            FontSize="75"
            HorizontalOptions="Center"
            Text="LoLStats"
            TextColor="White"
            VerticalOptions="Start" />

        <VerticalStackLayout
            Grid.Row="1"
            HorizontalOptions="Center"
            VerticalOptions="Center">
            <Label
                FontAttributes="Bold"
                FontSize="20"
                Text="Sök efter ett lol konto"
                TextColor="White" />
            <HorizontalStackLayout Spacing="20">
                <Entry
                    BackgroundColor="White"
                    Placeholder="Gamename#Tagline"
                    Text="{Binding LolName}"
                    WidthRequest="500" />
                <Button Command="{Binding SubmitCommand}" Text="Sök" />
            </HorizontalStackLayout>
            <Label
                FontAttributes="Bold"
                IsVisible="{Binding HasSearchHistory}"
                Text="Sök historik"
                TextColor="#8A8A9A" />
            <CollectionView
                HorizontalOptions="Start"
                IsVisible="{Binding HasSearchHistory}"
                ItemsSource="{Binding SearchHistory}"
                WidthRequest="500">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Label
                            Padding="8,4"
                            Text="{Binding}"
                            TextColor="#8A8A9A">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.SelectHistoryCommand}" CommandParameter="{Binding}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            <Label
                FontSize="20"
                HorizontalOptions="Center"
                Text="{Binding ErrorMessage}"
                TextColor="Red" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>