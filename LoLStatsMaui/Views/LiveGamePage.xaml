<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="LoLStatsMaui.Views.LiveGamePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    x:Name="ThisPage"
    BackgroundColor="#0A1428">
    <ScrollView>
        <Grid>
            <Label
                FontSize="20"
                HorizontalOptions="Center"
                IsVisible="{Binding HasError}"
                Text="{Binding ErrorMessage}"
                TextColor="Red"
                VerticalOptions="Center" />
            <ActivityIndicator
                HorizontalOptions="Center"
                IsRunning="{Binding IsLoading}"
                IsVisible="{Binding IsLoading}"
                VerticalOptions="Center"
                Color="#C89B3C" />
            <VerticalStackLayout IsVisible="{Binding ShowContent}" Spacing="16">
                <VerticalStackLayout
                    Margin="0,40,0,0"
                    HorizontalOptions="Center"
                    Spacing="8"
                    WidthRequest="400">
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="16">
                        <Grid HorizontalOptions="Start">
                            <Image
                                Aspect="AspectFill"
                                HeightRequest="90"
                                Source="{Binding SummonerOverview.ProfileIconString}"
                                WidthRequest="90">
                                <Image.Clip>
                                    <RoundRectangleGeometry CornerRadius="8" Rect="0,0,90,90" />
                                </Image.Clip>
                            </Image>
                            <Border
                                Margin="0,0,0,-10"
                                Padding="8,2"
                                BackgroundColor="#C89B3C"
                                HorizontalOptions="Center"
                                StrokeShape="RoundRectangle 10"
                                VerticalOptions="End">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="12"
                                    Text="{Binding SummonerOverview.Level}"
                                    TextColor="#1A1A2E" />
                            </Border>
                        </Grid>
                        <VerticalStackLayout Spacing="8" VerticalOptions="Center">
                            <HorizontalStackLayout Spacing="6">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="22"
                                    Text="{Binding SummonerOverview.SummonerName}"
                                    TextColor="White" />
                                <Label
                                    Margin="0,0,0,3"
                                    FontSize="14"
                                    Text="{Binding SummonerOverview.TagLine, StringFormat='#{0}'}"
                                    TextColor="#8A8A9A"
                                    VerticalOptions="End" />
                            </HorizontalStackLayout>
                            <Border
                                Padding="10,4"
                                BackgroundColor="#1E3A5F"
                                HorizontalOptions="Start"
                                Stroke="#2A5080"
                                StrokeShape="RoundRectangle 6"
                                StrokeThickness="1">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="13"
                                    Text="{Binding SummonerOverview.Region}"
                                    TextColor="#5B9BD5" />
                            </Border>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>

                    <!--  Game info  -->
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="16">
                        <Label
                            FontSize="14"
                            Text="{Binding SummonerOverview.CurrentLolMatch.GameMode}"
                            TextColor="#8A8A9A" />
                        <Label
                            FontSize="14"
                            Text="{Binding SummonerOverview.CurrentLolMatch.GameLength, Converter={StaticResource SecondsToTimeConverter}}"
                            TextColor="#8A8A9A" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <Label
                    FontSize="20"
                    HorizontalOptions="Center"
                    IsVisible="{Binding IsNotInGame}"
                    TextColor="#8A8A9A">
                    <Label.Text>
                        <MultiBinding StringFormat="{}{0} är just nu inte i en match">
                            <Binding Path="SummonerOverview.SummonerName" />
                        </MultiBinding>
                    </Label.Text>
                </Label>

                <!--  Teams  -->
                <VerticalStackLayout
                    Margin="0,20,0,40"
                    HorizontalOptions="Center"
                    IsVisible="{Binding IsNotInGame, Converter={toolkit:InvertedBoolConverter}}"
                    Spacing="16">

                    <!--  Blue team  -->
                    <Border
                        Padding="16"
                        BackgroundColor="#0A1F3D"
                        Stroke="#1E3A5F"
                        StrokeShape="RoundRectangle 10"
                        StrokeThickness="1"
                        WidthRequest="250">
                        <VerticalStackLayout Spacing="8">
                            <Label
                                FontAttributes="Bold"
                                FontSize="18"
                                HorizontalOptions="Center"
                                Text="Blue Team"
                                TextColor="#5B9BD5" />
                            <CollectionView
                                ItemsSource="{Binding BlueTeamPlayers}"
                                SelectedItem="{Binding SelectedPlayer, Mode=TwoWay}"
                                SelectionChangedCommand="{Binding Source={x:Reference ThisPage}, Path=BindingContext.NavigateToPlayerCommand}"
                                SelectionChangedCommandParameter="{Binding SelectedItem, Source={RelativeSource Self}}"
                                SelectionMode="Single"
                                VerticalOptions="Start">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <HorizontalStackLayout Margin="0,4" Spacing="12">
                                            <Image
                                                HeightRequest="40"
                                                Source="{Binding ChampionName, StringFormat='ChampionIcons/{0}.png'}"
                                                WidthRequest="40" />
                                            <Label
                                                FontAttributes="{Binding IsTargetPlayer, Converter={toolkit:BoolToObjectConverter TrueObject='Bold', FalseObject='None'}}"
                                                FontSize="14"
                                                Text="{Binding RiotId}"
                                                TextColor="{Binding IsTargetPlayer, Converter={toolkit:BoolToObjectConverter TrueObject='White', FalseObject='#8A8A9A'}}"
                                                VerticalOptions="Center" />
                                        </HorizontalStackLayout>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Border>

                    <!--  Red team  -->
                    <Border
                        Padding="16"
                        BackgroundColor="#3D0A0A"
                        Stroke="#5F1E1E"
                        StrokeShape="RoundRectangle 10"
                        StrokeThickness="1"
                        WidthRequest="250">
                        <VerticalStackLayout Spacing="8">
                            <Label
                                FontAttributes="Bold"
                                FontSize="18"
                                HorizontalOptions="Center"
                                Text="Red Team"
                                TextColor="#F44336" />
                            <CollectionView
                                ItemsSource="{Binding RedTeamPlayers}"
                                SelectedItem="{Binding SelectedPlayer, Mode=TwoWay}"
                                SelectionChangedCommand="{Binding Source={x:Reference ThisPage}, Path=BindingContext.NavigateToPlayerCommand}"
                                SelectionChangedCommandParameter="{Binding SelectedItem, Source={RelativeSource Self}}"
                                SelectionMode="Single"
                                VerticalOptions="Start">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <HorizontalStackLayout Margin="0,4" Spacing="12">
                                            <Image
                                                HeightRequest="40"
                                                Source="{Binding ChampionName, StringFormat='ChampionIcons/{0}.png'}"
                                                WidthRequest="40" />
                                            <Label
                                                FontAttributes="{Binding IsTargetPlayer, Converter={toolkit:BoolToObjectConverter TrueObject='Bold', FalseObject='None'}}"
                                                FontSize="14"
                                                Text="{Binding RiotId}"
                                                TextColor="{Binding IsTargetPlayer, Converter={toolkit:BoolToObjectConverter TrueObject='White', FalseObject='#8A8A9A'}}"
                                                VerticalOptions="Center" />
                                        </HorizontalStackLayout>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </Grid>

    </ScrollView>
</ContentPage>